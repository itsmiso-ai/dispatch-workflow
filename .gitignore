# Ignore everything by default.
*

# Allow Git metadata files.
!.gitignore
!README.md

# Allow docs.
!docs/
docs/*
!docs/heartbeat.md

# Allow cron prompt templates.
!cron-prompts/
cron-prompts/*
!cron-prompts/README.md
!cron-prompts/nightly-audit-decomposer.md
!cron-prompts/weekly-audit.md

# Allow scripts.
!scripts/
scripts/*
!scripts/audit_decompose.py
!scripts/project_groom.py

# Explicit never-track rules.
HEARTBEAT.md
cron/
cron/**
.state/
.state/**
*.env
.env
.env.*
*.log
*.key
*.pem
*.crt
*.token
*.secret
__pycache__/
*.pyc
*.bak
